# ═══════════════════════════════════════════════════════════
# Example tfvars — copy to terraform.tfvars and customize
# ═══════════════════════════════════════════════════════════

# Required: EC2 key pair for SSH access (must exist in AWS)
key_pair_name = "my-key-pair"

# Optional: AWS region (default: us-east-1)
# aws_region = "us-east-1"

# Optional: Instance type (default: t3.small)
# instance_type = "t3.small"

# Optional: Restrict SSH to your IP (recommended for production)
# allowed_ssh_cidr = "203.0.113.0/32"

# ─── Domain Setup (OPTIONAL) ─────────────────────────────
# Leave these commented out to use the ALB DNS name directly.
# Uncomment and set to use a custom domain with HTTPS.
#
# domain_name      = "hackeval.example.com"
# hosted_zone_name = "example.com"
# enable_https     = true
