# ═══════════════════════════════════════════════════════════
# Example tfvars — copy to terraform.tfvars and customize
# ═══════════════════════════════════════════════════════════
# No required variables! Just run: terraform init && terraform apply

# Optional: AWS region (default: us-east-1)
# aws_region = "us-east-1"

# Optional: Instance type (default: t3.small)
# instance_type = "t3.small"

# ─── SSH Access (OPTIONAL) ────────────────────────────────
# By default, access is via SSM Session Manager (no key pair needed).
# Uncomment to also enable SSH:
#
# key_pair_name  = "my-key-pair"
# allowed_ssh_cidr = "203.0.113.0/32"

# ─── Domain + HTTPS (OPTIONAL) ───────────────────────────
# By default, app is accessible via ALB DNS name (http only).
# Uncomment for custom domain with HTTPS:
#
# domain_name      = "hackeval.example.com"
# hosted_zone_name = "example.com"
# enable_https     = true
